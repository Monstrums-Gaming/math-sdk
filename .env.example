# Environment configuration for the mystery-box build service (service/).
#
# Copy to .env and fill in values:  cp .env.example .env
# The real .env is gitignored (never commit secrets). service/config.py loads this file
# from the repo root at startup (python-dotenv).
#
# NOTE: the AWS S3 upload path (uploads/aws_upload.py) reads a SEPARATE file,
# uploads/.env, for ACCESS_KEY / SECRET_KEY — it is unrelated to the build service.

# --- Required ---
# Shared secret the backoffice sends as the X-API-Key header. If unset, the service
# fails closed and rejects every /builds request. Use a long random string.
API_KEY=change-me-to-a-long-random-secret

# --- Optional (defaults shown) ---
# Max builds running at once. Builds are CPU-heavy (multiprocess sims); keep this low.
MAX_CONCURRENT_BUILDS=2

# Hard cap on a single build's wall-clock, in seconds. A prod build is minutes.
BUILD_TIMEOUT_SECONDS=1800

# Where per-job artifacts (snapshot publish files + publish.zip) are written.
# Relative paths resolve against the process CWD; default is service/artifacts/.
# ARTIFACT_DIR=service/artifacts

# The venv python that has the SDK installed. Default is the repo's ./env/bin/python.
# In the Docker image this is set to plain "python".
# PYTHON_BIN=env/bin/python

# --- uvicorn (consumed by service/run_service.sh, not config.py) ---
# HOST=0.0.0.0
# PORT=8000

# --- S3 deploy (optional) ---
# When AWS_S3_BUCKET is set, a successful PROD build auto-uploads its publish files to
# s3://<bucket>/<S3_PREFIX><game_id>/. This is YOUR bucket for the backoffice to store/
# serve — it does NOT publish the game to the Stake Engine RGS (that is the ACP dashboard).
# Leave AWS_S3_BUCKET blank to disable (builds still succeed; deploy_status = "skipped").
#
# AWS_S3_BUCKET is the bucket NAME ONLY — no slashes/path. Put any folder path in S3_PREFIX.
# e.g. objects at s3://juice-cdn/math-sdk/<game_id>/  =>  AWS_S3_BUCKET=juice-cdn
#                                                          S3_PREFIX=math-sdk/
# AWS_S3_BUCKET=my-backoffice-bucket
# S3_PREFIX=mystery-box/            # folder path under the bucket (trailing slash added if missing)
# AWS_REGION=us-east-1
# Credentials: if omitted, boto3's default chain is used (env, shared config, or IAM role).
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# S3_ENDPOINT_URL=                  # ONLY for S3-compatible stores (MinIO/LocalStack); leave unset for real AWS
# S3_PRESIGN_EXPIRY=3600            # seconds a presigned URL is valid (bonus, expires); 0 disables
# S3_PUBLIC_BASE_URL=https://cdn.example.com   # CDN/custom domain; returned as each file's stable `url`
#                                              # (= base/key). Unset => the S3 https URL is used.
# EPHEMERAL_BUILDS defaults ON when AWS_S3_BUCKET is set: a successful upload DELETES the local
# build (games/<id>/ + the job zip) so the service is stateless and S3 is the source of truth.
# The backoffice saves the returned s3_files[].url. Set false to also keep local copies.
# EPHEMERAL_BUILDS=true
